# Backend configuration

# OpenAI API configuration
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Path (absolute or relative to backend/) to the assortments folder
ASSORTMENTS_DIR=../assortments

# Maximum number of wines included in the LLM prompt (cap to keep it cheap/fast)
MAX_WINES_TO_LLM=80

# Allowed CORS origins (comma-separated). Use * for any.
CORS_ORIGINS=http://localhost:5173

LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=5000
